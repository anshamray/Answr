    "lint": "eslint \"src/**/*.{js,jsx,mjs,cjs}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,mjs,cjs}\" --fix",
    "format": "prettier \"src/**/*.{js,jsx,mjs,cjs,json,md}\" --check",
    "format:fix": "prettier \"src/**/*.{js,jsx,mjs,cjs,json,md}\" --write"
