# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/answr

# WebSocket
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=REDACTED_JWT_SECRET

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# OAuth Callback Base URL (backend URL)
OAUTH_CALLBACK_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=REDACTED_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REDACTED_GITHUB_CLIENT_SECRET

# ─── Email Configuration ─────────────────────────────────────────────────────
# Choose one provider: 'smtp', 'sendgrid', or 'resend'
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@yourdomain.com

# Option 1: SMTP (works with Gmail, Outlook, custom mail servers, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option 2: SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxx

# Option 3: Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxx
# Resend requires the sender domain (e.g. answr.ing in noreply@answr.ing) to be verified in the Resend dashboard.