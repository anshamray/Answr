# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/answr

# WebSocket
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=REDACTED_JWT_SECRET

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# OAuth Callback Base URL (backend URL)
OAUTH_CALLBACK_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=REDACTED_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REDACTED_GITHUB_CLIENT_SECRET