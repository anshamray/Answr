    "prettier": "^3.2.0",
    "tailwindcss": "^4.1.18",
    "vite": "^5.0.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "serve": "^14.2.4",
